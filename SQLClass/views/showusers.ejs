<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>All users</title>
    <style>
      table,
      th,
      td {
        border: 1px solid black;
        padding: 5px;
      }
      form {
        display: inline; /* make forms appear side by side */
      }
    </style>
  </head>
  <body>
    <table>
      <tr>
        <th>Id</th>
        <th>Username</th>
        <th>Email</th>
        <th>Actions</th>
      </tr>

      <% for (user of users) { %>
      <tr>
        <td><%= user.id %></td>
        <td><%= user.username %></td>
        <td><%= user.email %></td>
        <td>
          <form method="GET" action="/user/<%= user.id %>/edit">
            <button>Edit username</button>
          </form>
          <form method="GET" action="/user/<%= user.id %>/confirm-delete">
            <button>Delete</button>
          </form>
        </td>
      </tr>
      <% } %>
    </table>
  </body>
</html>
